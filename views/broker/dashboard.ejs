<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Broker Dashboard — Kenward</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>
        body { display: flex; min-height: 100vh; flex-direction: column; background: #f5f5f5; }
        main { flex: 1 0 auto; }
        .brand-logo { font-weight: 300; }
        .stats-card { padding: 20px; border-radius: 8px; color: white; }
    </style>
</head>
<body>

<nav class="blue-grey darken-4">
    <div class="nav-wrapper container">
        <a href="/" class="brand-logo">Kenward <span style="font-size: 14px; opacity: 0.7;">Pipeline</span></a>
        <ul id="nav-mobile" class="right hide-on-med-and-down">
            <li><a href="/api/v2/dev-dashboard"><i class="material-icons left">dashboard</i>Dashboard</a></li>
            <li><a href="#"><i class="material-icons left">settings</i>Settings</a></li>
        </ul>
    </div>
</nav>

<main class="container" style="margin-top: 30px;">
    <div class="row">
        <div class="col s12">
            <h4 class="grey-text text-darken-2"><%= companyName %></h4>
            <p class="grey-text"><%= slogan %></p>
        </div>
    </div>

    <div class="row">
        <div class="col s12">
            <div class="card">
                <div class="card-content">
                    <span class="card-title">Recent Leads</span>
                    <table class="highlight responsive-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Extracted Income</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (leads.length > 0) { %>
                                <% leads.forEach(lead => { %>
                                    <tr>
                                        <td><strong><%= lead.full_name %></strong></td>
                                        <td><%= lead.email || 'N/A' %></td>
                                        <td><span class="chip blue white-text"><%= lead.status.toUpperCase() %></span></td>
                                        <td>$<%= (lead.extracted_data?.income || 0).toLocaleString() %></td>
                                        <td><%= new Date(lead.created_at).toLocaleDateString() %></td>
                                        <td>
                                            <a href="#" class="btn-small waves-effect waves-light blue-grey"><i class="material-icons">visibility</i></a>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="center-align grey-text">No leads found in database.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</main>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>
