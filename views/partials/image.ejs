<div class="row">
    <div class="col s12 center-align">
        <% if (block.data.src) { %>
            <img src="<%- block.data.src %>" alt="<%- block.data.alt || 'Image' %>" class="responsive-img z-depth-1" style="max-height: 400px; margin-top: 20px;">
        <% } %>
        <% if (block.data.caption) { %>
            <p class="caption"><%- block.data.caption %></p>
        <% } %>
    </div>
</div>
